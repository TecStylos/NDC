#!/usr/bin/env bash
set -e

BIN_PATH="$HOME/.local/bin/ndc"
NIRI_CONFIG_DIR="$HOME/.config/niri"
NIRI_CONFIG="$NIRI_CONFIG_DIR/config.kdl"
NIRI_NDC_KDL="$NIRI_CONFIG_DIR/ndc.kdl"
HISTORY_DIR="$HOME/.config/ndc"

echo "=== Uninstalling NDC (Niri Display Configurator) ==="

# 1. Remove binaries
if [ -f "$BIN_PATH" ]; then
    echo "Removing executable $BIN_PATH..."
    rm "$BIN_PATH"
fi

# 3. Remove include from config.kdl
if [ -f "$NIRI_CONFIG" ]; then
    echo "Removing include \"ndc.kdl\" statement from config.kdl..."
    python3 -c "
with open('$NIRI_CONFIG', 'r') as f:
    lines = f.readlines()
new_lines = [l for l in lines if 'include \"ndc.kdl\"' not in l]
with open('$NIRI_CONFIG', 'w') as f:
    f.writelines(new_lines)
"
fi

# 4. Remove isolated ndc.kdl file
if [ -f "$NIRI_NDC_KDL" ]; then
    echo "Removing isolated configuration $NIRI_NDC_KDL..."
    rm "$NIRI_NDC_KDL"
fi

# 5. Remove history and configuration logs
if [ -d "$HISTORY_DIR" ]; then
    echo "Removing configuration history under $HISTORY_DIR..."
    rm -rf "$HISTORY_DIR"
fi

# 6. Clean logs
rm -f "$HOME/.cache/ndc.log" "$HOME/.cache/ndc-daemon.log"

echo "NDC uninstalled successfully!"
