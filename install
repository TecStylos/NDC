#!/usr/bin/env bash
set -e

# Target paths
BIN_DIR="$HOME/.local/bin"
BIN_PATH="$BIN_DIR/ndc"
DAEMON_PATH="$BIN_DIR/ndc-daemon"

NIRI_CONFIG_DIR="$HOME/.config/niri"
NIRI_CONFIG="$NIRI_CONFIG_DIR/config.kdl"
NIRI_RULES="$NIRI_CONFIG_DIR/cfg/rules.kdl"
NIRI_DISPLAY="$NIRI_CONFIG_DIR/cfg/display.kdl"
NIRI_KEYBINDS="$NIRI_CONFIG_DIR/cfg/keybinds.kdl"
NIRI_AUTO_DISPLAY="$NIRI_CONFIG_DIR/cfg/auto-display.kdl"
NIRI_NDC_KDL="$NIRI_CONFIG_DIR/ndc.kdl"

echo "=== Installing NDC (Niri Display Configurator) ==="

# 1. Copy executables
echo "Copying executables to $BIN_DIR..."
mkdir -p "$BIN_DIR"
cp ndc "$BIN_PATH"
cp ndc-daemon "$DAEMON_PATH"
chmod +x "$BIN_PATH" "$DAEMON_PATH"

# 2. Initialize history.json with currently connected monitors if it doesn't exist
echo "Initializing displays connection history..."
python3 -c "
import os, json, subprocess
history_dir = os.path.expanduser('~/.config/ndc')
history_path = os.path.join(history_dir, 'history.json')
if not os.path.exists(history_path):
    os.makedirs(history_dir, exist_ok=True)
    try:
        res = subprocess.run(['niri', 'msg', '--json', 'outputs'], capture_output=True, text=True, check=True)
        outputs = json.loads(res.stdout)
        sigs = []
        for name, info in outputs.items():
            make = info.get('make') or 'unknown'
            model = info.get('model') or 'unknown'
            serial = info.get('serial') or 'none'
            sigs.append(f'{make}-{model}-{serial}')
        with open(history_path, 'w') as f:
            json.dump(sigs, f, indent=4)
        print('Initialized display connection history with current outputs.')
    except Exception as e:
        with open(history_path, 'w') as f:
            json.dump([], f)
"

# 3. Clean up any remnants of old layout-helpers or auto-display inclusions
echo "Cleaning up old helper configurations..."

# Remove old include auto-display from display.kdl
if [ -f "$NIRI_DISPLAY" ]; then
    python3 -c "
with open('$NIRI_DISPLAY', 'r') as f:
    lines = f.readlines()
new_lines = [l for l in lines if 'auto-display.kdl' not in l]
with open('$NIRI_DISPLAY', 'w') as f:
    f.writelines(new_lines)
"
fi

# Remove old window-rules from rules.kdl
if [ -f "$NIRI_RULES" ]; then
    python3 -c "
import re
with open('$NIRI_RULES', 'r') as f:
    content = f.read()
pattern = r'\n\s*window-rule\s*\{\s*match\s+app-id=\"niri-display-helper\"\s*open-floating\s+true\s*\}'
new_content = re.sub(pattern, '', content)
pattern_fb = r'window-rule\s*\{\s*match\s+app-id=\"niri-display-helper\"\s*open-floating\s+true\s*\}'
new_content = re.sub(pattern_fb, '', new_content)
with open('$NIRI_RULES', 'w') as f:
    f.write(new_content)
"
fi

# Remove old keybinds from keybinds.kdl or config.kdl
for cfg_file in "$NIRI_KEYBINDS" "$NIRI_CONFIG"; do
    if [ -f "$cfg_file" ]; then
        python3 -c "
with open('$cfg_file', 'r') as f:
    lines = f.readlines()
new_lines = [l for l in lines if 'display-layout-helper' not in l and 'Mod+P' not in l]
with open('$cfg_file', 'w') as f:
    f.writelines(new_lines)
"
    fi
done

# Delete old auto-display.kdl file
if [ -f "$NIRI_AUTO_DISPLAY" ]; then
    rm -f "$NIRI_AUTO_DISPLAY"
fi

# 4. Generate the new unified self-contained ndc.kdl
echo "Generating unified ndc.kdl..."
python3 -c "
import os, json, subprocess
res = subprocess.run(['niri', 'msg', '--json', 'outputs'], capture_output=True, text=True)
outputs = json.loads(res.stdout) if res.returncode == 0 else {}

lines = [
    '// ==================================================',
    '// NDC - Niri Display Configurator Settings',
    '// This file is automatically managed by NDC.',
    '// ==================================================',
    '',
    '// --- Daemon Auto-start ---',
    'spawn-at-startup \"$DAEMON_PATH\"',
    '',
    '// --- App Keybind ---',
    'binds {',
    '    Mod+P { spawn \"$BIN_PATH\"; }',
    '}',
    '',
    '// --- App Window Rules ---',
    'window-rule {',
    '    match app-id=\"niri-display-helper\"',
    '    open-floating true',
    '}',
    '',
    '// --- Active Display Layouts ---'
]

for name, info in outputs.items():
    logical = info.get('logical', {}) or {}
    x = logical.get('x', 0)
    y = logical.get('y', 0)
    scale = logical.get('scale', 1.0)
    transform = logical.get('transform', 'normal').lower()
    modes = info.get('modes', [])
    curr_idx = info.get('current_mode', 0)
    
    lines.append(f'output \"{name}\" {{')
    if curr_idx is not None and curr_idx < len(modes):
        m = modes[curr_idx]
        refresh = m.get('refresh_rate', 60000) / 1000.0
        lines.append(f'    mode \"{m.get(\"width\")}x{m.get(\"height\")}@{refresh:.3f}\"')
    lines.append(f'    scale {scale}')
    lines.append(f'    transform \"{transform}\"')
    lines.append(f'    position x={x} y={y}')
    lines.append('}')
    lines.append('')

with open('$NIRI_NDC_KDL', 'w') as f:
    f.write('\n'.join(lines))
"

# 5. Add include ndc.kdl to config.kdl
if [ -f "$NIRI_CONFIG" ]; then
    if ! grep -q "include \"ndc.kdl\"" "$NIRI_CONFIG"; then
        echo "Adding include \"ndc.kdl\" statement to config.kdl..."
        echo -e "\ninclude \"ndc.kdl\"" >> "$NIRI_CONFIG"
    fi
fi

# 6. Ensure the daemon starts up immediately
if pgrep -f "$DAEMON_PATH" > /dev/null; then
    echo "Restarting active NDC hotplug daemon..."
    pkill -f "$DAEMON_PATH" || true
fi
echo "Launching NDC hotplug daemon..."
setsid "$DAEMON_PATH" > /home/tecstylos/nohup-install.log 2>&1 &

echo "NDC installed successfully! Press Mod+P to run."
