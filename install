#!/usr/bin/env bash
set -e

# Target paths
BIN_DIR="$HOME/.local/bin"
BIN_PATH="$BIN_DIR/ndc"
NIRI_CONFIG_DIR="$HOME/.config/niri"
NIRI_CONFIG="$NIRI_CONFIG_DIR/config.kdl"
NIRI_RULES="$NIRI_CONFIG_DIR/cfg/rules.kdl"
NIRI_DISPLAY="$NIRI_CONFIG_DIR/cfg/display.kdl"
NIRI_AUTO_DISPLAY="$NIRI_CONFIG_DIR/cfg/auto-display.kdl"

echo "=== Installing NDC (Niri Display Configurator) ==="

# 1. Copy executable
echo "Copying executable to $BIN_PATH..."
mkdir -p "$BIN_DIR"
cp ndc "$BIN_PATH"
chmod +x "$BIN_PATH"

# 2. Ensure auto-display.kdl exists with proper comments
if [ ! -f "$NIRI_AUTO_DISPLAY" ]; then
    echo "Creating auto-display.kdl..."
    mkdir -p "$(dirname "$NIRI_AUTO_DISPLAY")"
    cat << 'EOF' > "$NIRI_AUTO_DISPLAY"
// Generated by niri-display-helper
// Do not edit this file manually.
EOF
fi

# 3. Add include to display.kdl if not present
if [ -f "$NIRI_DISPLAY" ]; then
    if ! grep -q "include \"auto-display.kdl\"" "$NIRI_DISPLAY"; then
        echo "Adding include statement to display.kdl..."
        echo -e "\ninclude \"auto-display.kdl\"" >> "$NIRI_DISPLAY"
    fi
fi

# 4. Add window rule to rules.kdl if not present
if [ -f "$NIRI_RULES" ]; then
    if ! grep -q "app-id=\"niri-display-helper\"" "$NIRI_RULES"; then
        echo "Adding window rule to rules.kdl..."
        cat << 'EOF' >> "$NIRI_RULES"

window-rule {
    match app-id="niri-display-helper"
    open-floating true
}
EOF
    fi
fi

# 5. Add keybinding to config.kdl if not present
if [ -f "$NIRI_CONFIG" ]; then
    if ! grep -q "$BIN_PATH" "$NIRI_CONFIG"; then
        echo "Adding keybind Mod+P to config.kdl..."
        python3 -c "
import re
with open('$NIRI_CONFIG', 'r') as f:
    content = f.read()
if 'spawn \"$BIN_PATH\"' not in content:
    # Find binds { block and insert after the first brace
    new_content = re.sub(r'(binds\s*\{)', r'\1\n    Mod+P { spawn \"$BIN_PATH\"; }', content, count=1)
    with open('$NIRI_CONFIG', 'w') as f:
        f.write(new_content)
"
    fi
fi

echo "NDC installed successfully! Press Mod+P to run."
