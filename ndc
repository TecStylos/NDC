    def on_display_selected(self, display):
        self.selected_display = display
        ins = self.inspector
        
        ins.chk_enabled.blockSignals(True)
        ins.combo_mode.blockSignals(True)
        ins.spin_scale.blockSignals(True)
        ins.combo_transform.blockSignals(True)
        ins.spin_x.blockSignals(True)
        ins.spin_y.blockSignals(True)
        
        ins.lbl_name.setText(display.name)
        ins.chk_enabled.setChecked(display.enabled)
        
        ins.combo_mode.clear()
        for m in display.modes_list:
            mode_lbl = f"{m.get('width')}x{m.get('height')} @ {m.get('refresh_rate')/1000.0:.2f}Hz"
            if m.get("is_preferred"):
                mode_lbl += " (preferred)"
            ins.combo_mode.addItem(mode_lbl)
        ins.combo_mode.setCurrentIndex(display.current_mode_idx)
        
        ins.spin_scale.setValue(display.scale)
        
        trans_idx = ins.combo_transform.findText(display.transform)
        if trans_idx >= 0:
            ins.combo_transform.setCurrentIndex(trans_idx)
            
        ins.spin_x.setValue(display.x)
        ins.spin_y.setValue(display.y)
        
        ins.update_inspector_enabled_state(display.enabled)
        
        ins.chk_enabled.blockSignals(False)
        ins.combo_mode.blockSignals(False)
        ins.spin_scale.blockSignals(False)
        ins.combo_transform.blockSignals(False)
        ins.spin_x.blockSignals(False)
        ins.spin_y.blockSignals(False)
        
        self.canvas.update()

    def update_inspector_pos(self, x, y):
        ins = self.inspector
        ins.spin_x.blockSignals(True)
        ins.spin_y.blockSignals(True)
        ins.spin_x.setValue(x)
        ins.spin_y.setValue(y)
        ins.spin_x.blockSignals(False)
        ins.spin_y.blockSignals(False)

    def reset_layout(self):
        log("Reset layout clicked")
        for ic in self.initial_configs:
            for d in self.displays:
                if d.name == ic["name"]:
                    d.x = ic["x"]
                    d.y = ic["y"]
                    d.scale = ic["scale"]
                    d.transform = ic["transform"]
                    d.enabled = ic["enabled"]
                    d.current_mode_idx = ic["current_mode_idx"]
                    d.update_dimensions()
                    break
        
        if self.selected_display:
            self.on_display_selected(self.selected_display)
            
        self.canvas.update_viewport()
        self.canvas.update()

    def generate_kdl_content(self):
        lines = [
            "// Generated by niri-display-helper",
            "// Do not edit this file manually.",
            ""
        ]
        for d in self.displays:
            lines.append(f'output "{d.name}" {{')
            if not d.enabled:
                lines.append('    off')
            else:
                if 0 <= d.current_mode_idx < len(d.modes_list):
                    m = d.modes_list[d.current_mode_idx]
                    refresh_hz = m.get("refresh_rate", 60000) / 1000.0
                    lines.append(f'    mode "{m.get("width")}x{m.get("height")}@{refresh_hz:.3f}"')
                
                lines.append(f'    scale {d.scale}')
                lines.append(f'    transform "{d.transform}"')
                lines.append(f'    position x={d.x} y={d.y}')
                
            lines.append("}")
            lines.append("")
        return "\n".join(lines)

    def save_arrangement(self):
        log("Save arrangement clicked")
        new_content = self.generate_kdl_content()
        try:
            os.makedirs(os.path.dirname(AUTO_DISPLAY_PATH), exist_ok=True)
            with open(AUTO_DISPLAY_PATH, "w") as f:
                f.write(new_content)
            log("Saved KDL content to auto-display.kdl")
        except Exception as e:
            log(f"Error saving layout: {e}")
            QMessageBox.critical(self, "Error", f"Failed to save display layout:\n{e}")
            return
            
        self.confirming = True
        self.countdown_val = 10
        self.confirm_label.setText(f"New layout applied. Reverting in {self.countdown_val} seconds...")
        self.stacked_controls.setCurrentIndex(1)
        self.timer.start(1000)

    def update_countdown(self):
        self.countdown_val -= 1
        log(f"Countdown update: {self.countdown_val}")
        if self.countdown_val <= 0:
            self.timer.stop()
            self.revert_changes()
        else:
            self.confirm_label.setText(f"New layout applied. Reverting in {self.countdown_val} seconds...")

    def confirm_changes(self):
        log("Confirm changes clicked")
        self.timer.stop()
        self.confirming = False
        self.close()

    def revert_changes(self):
        log("Reverting changes")
        self.timer.stop()
        try:
            with open(AUTO_DISPLAY_PATH, "w") as f:
                f.write(self.original_kdl_content)
            log("Restored original KDL content")
        except Exception as e:
            log(f"Error reverting display layout: {e}")
        self.confirming = False
        self.close()

    def closeEvent(self, event):
        log("MainWindow closeEvent triggered")
        if self.confirming:
            self.revert_changes()
        event.accept()

    def keyPressEvent(self, event):
        if event.key() == Qt.Key.Key_Escape:
            log("Escape pressed, closing window")
            self.close()
        else:
            super().keyPressEvent(event)

def main():
    log("main() started")
    try:
        res = subprocess.run(["niri", "msg", "--json", "outputs"], capture_output=True, text=True, check=True)
        outputs_json = json.loads(res.stdout)
        log(f"Niri outputs queried successfully: {res.stdout.strip()}")
    except Exception as e:
        log(f"Failed to query Niri outputs: {e}")
        app = QApplication(sys.argv)
        QMessageBox.critical(None, "Niri Connection Error", 
                             f"Failed to communicate with Niri compositor.\n"
                             f"Are you running inside a Niri session?\n\nError: {e}")
        sys.exit(1)
        
    if not outputs_json:
        log("No outputs found in Niri json")
        app = QApplication(sys.argv)
        QMessageBox.warning(None, "No Displays Found", "Niri reported no connected displays.")
        sys.exit(1)
        
    displays = []
    for name, info in outputs_json.items():
        logical = info.get("logical")
        modes_list = info.get("modes", [])
        current_mode_idx = info.get("current_mode", 0)
        
        if logical:
            x = logical.get("x", 0)
            y = logical.get("y", 0)
            scale = logical.get("scale", 1.0)
            transform = logical.get("transform", "normal").lower()
            enabled = True
        else:
            x, y = 0, 0
            scale = 1.0
            transform = "normal"
            enabled = True
            
        model = info.get("model", "")
        make = info.get("make", "")
        
        displays.append(DisplayItem(
            name=name, x=x, y=y, scale=scale, transform=transform,
            enabled=enabled, model=model, make=make,
            modes_list=modes_list, current_mode_idx=current_mode_idx
        ))
        log(f"Appended display item: {name}, pos=({x},{y}), scale={scale}, transform={transform}")

    app = QApplication(sys.argv)
    app.setApplicationName("niri-display-helper")
    app.setDesktopFileName("niri-display-helper")
    
    win = MainWindow(displays)
    win.show()
    log("win.show() called")
    sys.exit(app.exec())

if __name__ == "__main__":
    main()
