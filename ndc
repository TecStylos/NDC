        self.lbl_scale.setStyleSheet("font-size: 13px; color: #e2e8f0;")
        layout.addWidget(self.lbl_scale)
        
        self.spin_scale = QDoubleSpinBox()
        self.spin_scale.setRange(0.5, 5.0)
