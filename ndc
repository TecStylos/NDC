def log(msg):
    try:
        os.makedirs(os.path.dirname(LOG_PATH), exist_ok=True)
        with open(LOG_PATH, "a") as f:
            f.write(f"{msg}\n")
    except Exception as e:
        print(f"Failed to log: {e}", file=sys.stderr)

# Clear old log on startup
try:
    if os.path.exists(LOG_PATH):
        os.remove(LOG_PATH)
except Exception:
    pass

class DisplayItem:
    def __init__(self, name, x, y, scale, transform, enabled, model, make, modes_list, current_mode_idx):
        self.name = name
        self.x = x
        self.y = y
        self.scale = scale
        self.transform = transform
        self.enabled = enabled
        self.model = model
        self.make = make
        self.modes_list = modes_list
        self.current_mode_idx = current_mode_idx
        
        self.width = 1920
        self.height = 1080
        self.raw_width = 1920
        self.raw_height = 1080
        self.refresh_rate = 60.0
        
        self.update_dimensions()

    def update_dimensions(self):
        if 0 <= self.current_mode_idx < len(self.modes_list):
            raw_w = self.modes_list[self.current_mode_idx].get("width", 1920)
            raw_h = self.modes_list[self.current_mode_idx].get("height", 1080)
            self.refresh_rate = self.modes_list[self.current_mode_idx].get("refresh_rate", 60000) / 1000.0
        else:
            raw_w = 1920
            raw_h = 1080
            self.refresh_rate = 60.0
            
        self.raw_width = raw_w
        self.raw_height = raw_h

        is_rotated_90_270 = self.transform in ["90", "270", "flipped-90", "flipped-270"]
        if is_rotated_90_270:
            logical_w = raw_h
            logical_h = raw_w
        else:
            logical_w = raw_w
            logical_h = raw_h
            
        self.width = max(50, int(logical_w / max(0.1, self.scale)))
        self.height = max(50, int(logical_h / max(0.1, self.scale)))

class DisplayCanvas(QWidget):
    def __init__(self, displays, main_window, parent=None):
        super().__init__(parent)
        self.displays = displays
        self.main_window = main_window
        self.dragged_display = None
        self.drag_start_mouse = QPointF(0, 0)
        self.drag_start_logical_pos = QPointF(0, 0)
        
        self.canvas_scale = 1.0
        self.offset_x = 0
        self.offset_y = 0
        self.logical_bounds = None
        
        self.active_snap_x_line = None
        self.active_snap_y_line = None
        
        self.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)
        self.setMinimumSize(400, 300)
        self.setMouseTracking(True)
        
        log(f"DisplayCanvas init: displays count = {len(self.displays)}")
        self.update_viewport()

    def update_viewport(self):
        if not self.displays:
            return
        
        min_x = min(d.x for d in self.displays)
        max_x = max(d.x + d.width for d in self.displays)
        min_y = min(d.y for d in self.displays)
        max_y = max(d.y + d.height for d in self.displays)
        
        margin = 400
        min_x -= margin
        max_x += margin
        min_y -= margin
        max_y += margin
        
        self.logical_bounds = QRectF(min_x, min_y, max_x - min_x, max_y - min_y)
        self.calculate_scale()

    def calculate_scale(self):
        if not self.logical_bounds or self.width() == 0 or self.height() == 0:
            return
            
        scale_x = self.width() / self.logical_bounds.width()
        scale_y = self.height() / self.logical_bounds.height()
        self.canvas_scale = min(scale_x, scale_y)
        
        w_width = self.logical_bounds.width() * self.canvas_scale
        w_height = self.logical_bounds.height() * self.canvas_scale
        
        self.offset_x = (self.width() - w_width) / 2 - self.logical_bounds.x() * self.canvas_scale
        self.offset_y = (self.height() - w_height) / 2 - self.logical_bounds.y() * self.canvas_scale

    def to_widget_x(self, lx):
        return lx * self.canvas_scale + self.offset_x

    def to_widget_y(self, ly):
        return ly * self.canvas_scale + self.offset_y

    def to_logical_x(self, wx):
        return (wx - self.offset_x) / self.canvas_scale

    def to_logical_y(self, wy):
        return (wy - self.offset_y) / self.canvas_scale

    def resizeEvent(self, event):
        super().resizeEvent(event)
        self.calculate_scale()
        self.update()

    def mousePressEvent(self, event):
        if event.button() == Qt.MouseButton.LeftButton:
            pos = event.position()
            selected = None
            for d in reversed(self.displays):
                wx = self.to_widget_x(d.x)
                wy = self.to_widget_y(d.y)
                ww = d.width * self.canvas_scale
                wh = d.height * self.canvas_scale
                rect = QRectF(wx, wy, ww, wh)
                
                if rect.contains(pos):
                    selected = d
                    self.displays.remove(d)
                    self.displays.append(d)
                    break
            
            if selected:
                self.dragged_display = selected
                self.drag_start_mouse = pos
                self.drag_start_logical_pos = QPointF(selected.x, selected.y)
                self.main_window.on_display_selected(selected)
                self.update()

    def mouseMoveEvent(self, event):
        if self.dragged_display:
            offset_widget = event.position() - self.drag_start_mouse
            offset_logical_x = offset_widget.x() / self.canvas_scale
            offset_logical_y = offset_widget.y() / self.canvas_scale
            
            new_x = self.drag_start_logical_pos.x() + offset_logical_x
            new_y = self.drag_start_logical_pos.y() + offset_logical_y
            
            shift_pressed = bool(event.modifiers() & Qt.KeyboardModifier.ShiftModifier)
            
            self.active_snap_x_line = None
            self.active_snap_y_line = None
            
            if not shift_pressed:
                best_dx = float('inf')
                best_dy = float('inf')
                threshold = 16 / self.canvas_scale
                
                snap_x = new_x
                snap_y = new_y
                
                for other in self.displays:
                    if other == self.dragged_display or not other.enabled:
                        continue
                    
                    dx = other.x + other.width - new_x
                    if abs(dx) < threshold and abs(dx) < abs(best_dx):
                        best_dx = dx
                        snap_x = other.x + other.width
                        self.active_snap_x_line = snap_x
                        
                    dx = other.x - (new_x + self.dragged_display.width)
                    if abs(dx) < threshold and abs(dx) < abs(best_dx):
                        best_dx = dx
                        snap_x = other.x - self.dragged_display.width
                        self.active_snap_x_line = other.x
                        
                    dx = other.x - new_x
                    if abs(dx) < threshold and abs(dx) < abs(best_dx):
                        best_dx = dx
                        snap_x = other.x
                        self.active_snap_x_line = other.x
                        
                    dx = other.x + other.width - (new_x + self.dragged_display.width)
                    if abs(dx) < threshold and abs(dx) < abs(best_dx):
                        best_dx = dx
                        snap_x = other.x + other.width - self.dragged_display.width
                        self.active_snap_x_line = other.x + other.width

                    dy = other.y + other.height - new_y
                    if abs(dy) < threshold and abs(dy) < abs(best_dy):
                        best_dy = dy
                        snap_y = other.y + other.height
                        self.active_snap_y_line = snap_y
                        
                    dy = other.y - (new_y + self.dragged_display.height)
                    if abs(dy) < threshold and abs(dy) < abs(best_dy):
                        best_dy = dy
                        snap_y = other.y - self.dragged_display.height
                        self.active_snap_y_line = other.y
                        
                    dy = other.y - new_y
                    if abs(dy) < threshold and abs(dy) < abs(best_dy):
                        best_dy = dy
                        snap_y = other.y
                        self.active_snap_y_line = other.y
                        
                    dy = other.y + other.height - (new_y + self.dragged_display.height)
                    if abs(dy) < threshold and abs(dy) < abs(best_dy):
                        best_dy = dy
                        snap_y = other.y + other.height - self.dragged_display.height
                        self.active_snap_y_line = other.y + other.height
                
                if abs(best_dx) < threshold:
                    new_x = snap_x
                if abs(best_dy) < threshold:
                    new_y = snap_y
            
            self.dragged_display.x = round(new_x)
            self.dragged_display.y = round(new_y)
            
            self.main_window.update_inspector_pos(self.dragged_display.x, self.dragged_display.y)
            self.update()

    def mouseReleaseEvent(self, event):
        if event.button() == Qt.MouseButton.LeftButton:
            self.dragged_display = None
            self.active_snap_x_line = None
            self.active_snap_y_line = None
            self.update_viewport()
            self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        
        painter.fillRect(self.rect(), QColor("#0d0e12"))
        
        if self.logical_bounds:
            grid_spacing = 100
            while grid_spacing * self.canvas_scale < 30:
                grid_spacing *= 2
                
            grid_pen = QPen(QColor("#1a1c23"), 1, Qt.PenStyle.SolidLine)
            painter.setPen(grid_pen)
            
            start_x = int(self.logical_bounds.x() // grid_spacing * grid_spacing)
            end_x = int((self.logical_bounds.x() + self.logical_bounds.width()) // grid_spacing * grid_spacing + grid_spacing)
            for lx in range(start_x, end_x, grid_spacing):
                wx = self.to_widget_x(lx)
                painter.drawLine(int(wx), 0, int(wx), self.height())
                
            start_y = int(self.logical_bounds.y() // grid_spacing * grid_spacing)
            end_y = int((self.logical_bounds.y() + self.logical_bounds.height()) // grid_spacing * grid_spacing + grid_spacing)
            for ly in range(start_y, end_y, grid_spacing):
                wy = self.to_widget_y(ly)
                painter.drawLine(0, int(wy), self.width(), int(wy))

        if self.active_snap_x_line is not None:
            wx = self.to_widget_x(self.active_snap_x_line)
            painter.setPen(QPen(QColor("#38bdf8"), 1.5, Qt.PenStyle.DashLine))
            painter.drawLine(int(wx), 0, int(wx), self.height())
            
        if self.active_snap_y_line is not None:
            wy = self.to_widget_y(self.active_snap_y_line)
            painter.setPen(QPen(QColor("#38bdf8"), 1.5, Qt.PenStyle.DashLine))
            painter.drawLine(0, int(wy), self.width(), int(wy))

        for d in self.displays:
            is_dragged = (d == self.dragged_display)
            is_selected = (d == self.main_window.selected_display)
            
            wx = self.to_widget_x(d.x)
            wy = self.to_widget_y(d.y)
            ww = d.width * self.canvas_scale
            wh = d.height * self.canvas_scale
            
            rect = QRectF(wx, wy, ww, wh)
            
            grad = QLinearGradient(rect.topLeft(), rect.bottomLeft())
            if not d.enabled:
                grad.setColorAt(0.0, QColor("#1c1d24"))
                grad.setColorAt(1.0, QColor("#111216"))
                border_color = QColor("#2e303d")
                border_width = 2
            elif is_dragged:
                grad.setColorAt(0.0, QColor("#1e293b"))
                grad.setColorAt(1.0, QColor("#0f172a"))
                border_color = QColor("#38bdf8")
                border_width = 3
            elif is_selected:
                grad.setColorAt(0.0, QColor("#2e184a"))
                grad.setColorAt(1.0, QColor("#170928"))
                border_color = QColor("#a855f7")
                border_width = 3
            else:
                grad.setColorAt(0.0, QColor("#222530"))
                grad.setColorAt(1.0, QColor("#161821"))
                border_color = QColor("#475569")
                border_width = 2
                
            painter.setBrush(QBrush(grad))
            painter.setPen(QPen(border_color, border_width, Qt.PenStyle.SolidLine))
            painter.drawRoundedRect(rect, 8, 8)
            
            if not d.enabled:
                painter.setPen(QPen(QColor("#2e303d"), 1, Qt.PenStyle.DotLine))
                painter.drawLine(int(wx), int(wy), int(wx + ww), int(wy + wh))
                painter.drawLine(int(wx + ww), int(wy), int(wx), int(wy + wh))

            painter.setPen(QColor("#f8fafc") if d.enabled else QColor("#64748b"))
            
            font_title = QFont("Inter", 12, QFont.Weight.Bold)
            painter.setFont(font_title)
            title_text = f"{d.name}"
            if d.model:
                title_text += f" ({d.model})"
            if not d.enabled:
                title_text += " [OFF]"
            painter.drawText(int(wx + 12), int(wy + 28), title_text)
            
            font_details = QFont("Inter", 9, QFont.Weight.Normal)
            painter.setFont(font_details)
            painter.setPen(QColor("#94a3b8") if d.enabled else QColor("#475569"))
            
            res_text = f"Resolution: {d.raw_width}x{d.raw_height} @ {d.refresh_rate:.1f}Hz"
            scale_text = f"Scale: {d.scale:.2f}"
            pos_text = f"Pos: x={d.x}, y={d.y}"
            
            painter.drawText(int(wx + 12), int(wy + 48), res_text)
            painter.drawText(int(wx + 12), int(wy + 65), scale_text)
            painter.drawText(int(wx + 12), int(wy + 82), pos_text)

