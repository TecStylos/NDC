        self.lbl_transform.setStyleSheet("font-size: 13px; color: #e2e8f0;")
        layout.addWidget(self.lbl_transform)
        
        self.combo_transform = QComboBox()
        self.combo_transform.addItems([
            "normal", "90", "180", "270",
            "flipped", "flipped-90", "flipped-180", "flipped-270"
        ])
        self.combo_transform.currentIndexChanged.connect(self.on_transform_changed)
        layout.addWidget(self.combo_transform)
        
        self.lbl_position = QLabel("Logical Position Coordinates:")
        self.lbl_position.setStyleSheet("font-size: 13px; color: #e2e8f0;")
        layout.addWidget(self.lbl_position)
        
        coords_layout = QHBoxLayout()
        
        x_layout = QHBoxLayout()
        x_lbl = QLabel("X:")
        x_lbl.setStyleSheet("font-size: 13px; color: #94a3b8;")
        self.spin_x = QSpinBox()
        self.spin_x.setRange(-20000, 20000)
        self.spin_x.setSingleStep(10)
        self.spin_x.valueChanged.connect(self.on_pos_changed)
        x_layout.addWidget(x_lbl)
        x_layout.addWidget(self.spin_x)
        
        y_layout = QHBoxLayout()
        y_lbl = QLabel("Y:")
        y_lbl.setStyleSheet("font-size: 13px; color: #94a3b8;")
        self.spin_y = QSpinBox()
        self.spin_y.setRange(-20000, 20000)
        self.spin_y.setSingleStep(10)
        self.spin_y.valueChanged.connect(self.on_pos_changed)
        y_layout.addWidget(y_lbl)
        y_layout.addWidget(self.spin_y)
        
        coords_layout.addLayout(x_layout)
        coords_layout.addLayout(y_layout)
        layout.addLayout(coords_layout)
        
        layout.addStretch()

    def update_inspector_enabled_state(self, enabled):
        self.combo_mode.setEnabled(enabled)
        self.spin_scale.setEnabled(enabled)
        self.combo_transform.setEnabled(enabled)
        self.spin_x.setEnabled(enabled)
        self.spin_y.setEnabled(enabled)

    def on_enabled_toggled(self, checked):
        d = self.main_win.selected_display
        if d:
            d.enabled = checked
            self.update_inspector_enabled_state(checked)
            self.main_win.canvas.update()

    def on_mode_changed(self, idx):
        d = self.main_win.selected_display
        if d and idx >= 0:
            d.current_mode_idx = idx
            d.update_dimensions()
            self.main_win.canvas.update_viewport()
            self.main_win.canvas.update()

    def on_scale_changed(self, val):
        d = self.main_win.selected_display
        if d:
            d.scale = val
            d.update_dimensions()
            self.main_win.canvas.update_viewport()
            self.main_win.canvas.update()

    def on_transform_changed(self, idx):
        d = self.main_win.selected_display
        if d:
            d.transform = self.combo_transform.currentText()
            d.update_dimensions()
            self.main_win.canvas.update_viewport()
            self.main_win.canvas.update()

    def on_pos_changed(self, val):
        d = self.main_win.selected_display
        if d:
            d.x = self.spin_x.value()
            d.y = self.spin_y.value()
            self.main_win.canvas.update_viewport()
            self.main_win.canvas.update()

